          "query": "SELECT\n  ServiceName AS service,\n  count() AS request_count,\n  countIf(toUInt64OrZero(SpanAttributes['http.status_code']) >= 400) / count() * 100 AS error_rate,\n  avg(Duration / 1000000) AS avg_duration_ms,\n  quantile(0.95)(Duration / 1000000) AS p95_duration_ms\nFROM otel_traces\nWHERE Timestamp > now() - INTERVAL ${__interval_s} SECOND\n  AND ParentSpanId = ''\n  AND SpanKind = 'server'\n  AND ($service = 'All' OR ServiceName = $service)\n  AND ($environment = 'All' OR ResourceAttributes['deployment.environment'] = $environment)\nGROUP BY service\nORDER BY request_count DESC",
