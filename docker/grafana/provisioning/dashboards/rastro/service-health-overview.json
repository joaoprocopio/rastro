      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "rastro-clickhouse-datasource"
          },
          "query": "SELECT\n  concat(toString(SpanAttributes['http.status_code']), ' - ',\n    CASE\n      WHEN toUInt64OrZero(SpanAttributes['http.status_code']) >= 200 AND toUInt64OrZero(SpanAttributes['http.status_code']) < 300 THEN 'OK'\n      WHEN toUInt64OrZero(SpanAttributes['http.status_code']) >= 300 AND toUInt64OrZero(SpanAttributes['http.status_code']) < 400 THEN 'Redirect'\n      WHEN toUInt64OrZero(SpanAttributes['http.status_code']) >= 400 AND toUInt64OrZero(SpanAttributes['http.status_code']) < 500 THEN 'Client Error'\n      WHEN toUInt64OrZero(SpanAttributes['http.status_code']) >= 500 THEN 'Server Error'\n      ELSE 'Unknown'\n    END\n  ) AS status,\n  sum(Duration / 1000000) AS total_duration\nFROM otel_traces\nWHERE Timestamp > now() - INTERVAL ${__interval_s} SECOND\n  AND ParentSpanId = ''\n  AND SpanKind = 'server'\n  AND ($service = 'All' OR ServiceName = $service)\n  AND ($environment = 'All' OR ResourceAttributes['deployment.environment'] = $environment)\nGROUP BY status\nORDER BY total_duration DESC",
          "rawQuery": true,
          "refId": "A"
        }
      ],
