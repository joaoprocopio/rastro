          "query": "SELECT\n  toStartOfInterval(Timestamp, INTERVAL $__interval SECOND) AS time,\n  countIf(toUInt64OrZero(SpanAttributes['http.status_code']) >= 200 AND toUInt64OrZero(SpanAttributes['http.status_code']) < 300) / ${__interval_s} AS \"2xx\",\n  countIf(toUInt64OrZero(SpanAttributes['http.status_code']) >= 400 AND toUInt64OrZero(SpanAttributes['http.status_code']) < 500) / ${__interval_s} AS \"4xx\",\n  countIf(toUInt64OrZero(SpanAttributes['http.status_code']) >= 500) / ${__interval_s} AS \"5xx\"\nFROM otel_traces\nWHERE Timestamp > now() - INTERVAL ${__from:date:seconds}s\n  AND Timestamp < now() - INTERVAL ${__to:date:seconds}s\n  AND ParentSpanId = ''\n  AND SpanKind = 'server'\n  AND ($service = 'All' OR ServiceName = $service)\n  AND ($environment = 'All' OR ResourceAttributes['deployment.environment'] = $environment)\nGROUP BY time\nORDER BY time",
