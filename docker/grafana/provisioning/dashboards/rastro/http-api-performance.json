        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${DS_CLICKHOUSE}"
          },
          "query": "SELECT\n  SpanName AS endpoint,\n  count() AS request_count,\n  countIf(toUInt64OrZero(SpanAttributes['http.status_code']) >= 400) AS error_count,\n  round(avg(Duration / 1000000), 2) AS avg_duration_ms,\n  round(quantile(0.50)(Duration / 1000000), 2) AS p50_ms,\n  round(quantile(0.95)(Duration / 1000000), 2) AS p95_ms,\n  round(quantile(0.99)(Duration / 1000000), 2) AS p99_ms\nFROM otel_traces\nWHERE Timestamp > now() - INTERVAL ${__interval_s} SECOND\n  AND ParentSpanId = ''\n  AND SpanKind = 'server'\n  AND ($service = 'All' OR ServiceName = $service)\n  AND ($environment = 'All' OR ResourceAttributes['deployment.environment'] = $environment)\nGROUP BY endpoint\nORDER BY request_count DESC\nLIMIT 20",
          "rawQuery": true,
          "refId": "A"
        }
      ],
      "title": "Top 20 Endpoints by Request Count",
      "type": "table"
