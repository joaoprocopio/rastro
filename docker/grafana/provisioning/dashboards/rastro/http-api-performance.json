          "query": "SELECT\n  toStartOfInterval(Timestamp, INTERVAL $__interval SECOND) AS time,\n  SpanName AS endpoint,\n  count() / ${__interval_s} AS throughput\nFROM otel_traces\nWHERE Timestamp > now() - INTERVAL ${__from:date:seconds}s\n  AND Timestamp < now() - INTERVAL ${__to:date:seconds}s\n  AND ParentSpanId = ''\n  AND SpanKind = 'server'\n  AND ($service = 'All' OR ServiceName = $service)\n  AND ($environment = 'All' OR ResourceAttributes['deployment.environment'] = $environment)\nGROUP BY time, endpoint\nORDER BY time",
